# Copy this to .env and fill in your values

# Hostname Traefik will route to this app
APP_HOSTNAME=dinner.home

# Port uvicorn listens on (also used in Traefik loadbalancer label)
APP_PORT=8000

# AI provider: "anthropic", "openai", or "none" to disable AI suggestions
AI_PROVIDER=anthropic

# API key for whichever provider is active above
AI_API_KEY=
